---
import "../styles/main.css";

interface Props {
  title?: string;
}

const { title = "Jorge Ares Pons" } = Astro.props;

const links: { href: string; label: string }[] = [
  {
    href: "/evaluacion-y-acreditacion-apacet",
    label: "Evaluación y acreditación. APACET",
  },
  { href: "/libros-otros", label: "Libros/Otros" },
  { href: "/universidad-y-pedeciba", label: "Universidad y PEDECIBA" },
  { href: "/universidad-y-sociedad", label: "Universidad y Sociedad" },
  { href: "/universidades-privadas", label: "Universidades Privadas" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Jorge Ares Pons, página personal" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,400;0,700;1,400&family=Playfair+Display:wght@500&display=swap"
      rel="stylesheet"
    />
    <link rel="author" href="https://ares.uy" />
    <meta name="author" content="Ares Software" />
    <link rel="icon" href="data:image/png;base64,iVBORw0KGgo=" />
    <!-- Global site tag (gtag.js) - Google Analytics -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-1ETL6R5H92"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-1ETL6R5H92");
    </script>
    <script src="../scripts/main.ts"></script>
  </head>
  <body>
    <a class="visually-hidden-focusable skip-main" href="#content">
      Ir al contenido
    </a>
    <header class="header">
      <nav class="nav content">
        <a class="nav__title" href="/">Jorge Ares Pons</a>
        <button
          type="button"
          class="nav__toggler"
          js-nav-toggle="main-nav"
          aria-controls="nav-main"
          aria-expanded="false"
          aria-label="Abrir/Cerrar menú"
        >
          <div class="icon-burger">
            <span class="icon-burger__line"></span>
            <span class="icon-burger__line"></span>
            <span class="icon-burger__line"></span>
          </div>
        </button>
        <div class="nav__menu" id="nav-main" js-nav="main-nav">
          <ul class="nav__list" js-nav-content>
            {
              links.map((link) => (
                <li class="nav__item">
                  <a
                    class={`nav__link ${currentPath === link.href ? "active" : undefined}`}
                    aria-current={
                      currentPath === link.href ? "page" : undefined
                    }
                    href={link.href}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="footer">
      <div class="footer__content content">
        Contacto:
        <a class="footer__link" href="mailto:fermin@ares.uy" target="_blank">
          fermin@ares.uy
        </a>
      </div>
    </footer>
  </body>
</html>
